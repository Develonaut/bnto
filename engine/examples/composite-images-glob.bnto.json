{
  "id": "composite-images-glob",
  "type": "group",
  "version": "1.0.0",
  "name": "Composite Images with Overlay (Glob Pattern)",
  "position": {
    "x": 0,
    "y": 0
  },
  "metadata": {
    "description": "Uses a glob pattern to filter specific image types (e.g., *.png or *.jpg), composites an overlay on each, and saves to an output folder.",
    "usage": "INPUT_PATTERN='images/*.png' OUTPUT_DIR=output OVERLAY=overlay.png ./bnto run examples/composite-images-glob.bnto.json",
    "example": "Processes only PNG files matching 'renders/*.png' pattern",
    "tags": ["images", "composite", "overlay", "loop", "batch", "glob"],
    "demonstrates": ["list with glob pattern", "forEach loop", "image composite"]
  },
  "variables": [
    {
      "name": "INPUT_PATTERN",
      "description": "Glob pattern for input images (e.g., 'images/*.png' or 'photos/**/*.jpg')",
      "type": "string"
    },
    {
      "name": "OUTPUT_DIR",
      "description": "Directory where composited images will be saved",
      "type": "path"
    },
    {
      "name": "OVERLAY",
      "description": "Path to the overlay image to composite on top of each input image",
      "type": "path"
    }
  ],
  "parameters": {},
  "inputPorts": [],
  "outputPorts": [],
  "nodes": [
    {
      "id": "list-images",
      "type": "file-system",
      "version": "1.0.0",
      "name": "List Images by Pattern",
      "position": {
        "x": 100,
        "y": 100
      },
      "metadata": {
        "description": "Lists all image files matching the glob pattern. For example: '*.png' matches all PNGs in current dir, 'images/**/*.jpg' matches all JPGs recursively in images/ folder."
      },
      "parameters": {
        "operation": "list",
        "path": "{{.INPUT_PATTERN}}"
      },
      "inputPorts": [],
      "outputPorts": [
        {
          "id": "out-1",
          "name": "files"
        }
      ]
    },
    {
      "id": "create-output-dir",
      "type": "file-system",
      "version": "1.0.0",
      "name": "Create Output Directory",
      "position": {
        "x": 100,
        "y": 200
      },
      "metadata": {
        "description": "Creates the output directory if it doesn't exist"
      },
      "parameters": {
        "operation": "mkdir",
        "path": "{{.OUTPUT_DIR}}",
        "recursive": true
      },
      "inputPorts": [],
      "outputPorts": []
    },
    {
      "id": "composite-loop",
      "type": "loop",
      "version": "1.0.0",
      "name": "Composite Each Image",
      "position": {
        "x": 300,
        "y": 100
      },
      "metadata": {
        "description": "Loops through each matched image file and composites the overlay on top"
      },
      "parameters": {
        "mode": "forEach",
        "items": "{{index . \"list-images\" \"files\"}}",
        "showProgress": true
      },
      "inputPorts": [
        {
          "id": "in-1",
          "name": "items"
        }
      ],
      "outputPorts": [],
      "nodes": [
        {
          "id": "composite-image",
          "type": "image",
          "version": "1.0.0",
          "name": "Composite Overlay",
          "position": {
            "x": 100,
            "y": 100
          },
          "metadata": {
            "description": "Composites the overlay centered on each base image"
          },
          "parameters": {
            "operation": "composite",
            "base": "{{.item}}",
            "overlay": "{{$.OVERLAY}}",
            "output": "{{$.OUTPUT_DIR}}/{{basename .item}}",
            "position": "center",
            "format": "png",
            "quality": 95
          },
          "inputPorts": [],
          "outputPorts": []
        }
      ],
      "edges": []
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "list-images",
      "target": "composite-loop",
      "sourcePort": "out-1",
      "targetPort": "in-1"
    }
  ]
}
