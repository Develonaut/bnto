{
  "id": "composite-images-with-overlay",
  "type": "group",
  "version": "1.0.0",
  "name": "Composite Images with Overlay",
  "position": {
    "x": 0,
    "y": 0
  },
  "metadata": {
    "description": "Loops through all images in a source folder, composites an overlay on top of each image, and saves the results to an output folder. Great for batch watermarking or adding branding overlays.",
    "usage": "INPUT_DIR=path/to/images OUTPUT_DIR=path/to/output OVERLAY=path/to/overlay.png ./bento run examples/composite-images-with-overlay.bento.json",
    "example": "Reads all images from images/ folder, composites overlay.png on top, and saves to images-with-overlay/ folder.",
    "tags": ["images", "composite", "overlay", "loop", "batch"],
    "demonstrates": ["list operation", "forEach loop", "image composite", "mkdir"]
  },
  "variables": [
    {
      "name": "INPUT_DIR",
      "description": "Directory containing input images",
      "type": "path"
    },
    {
      "name": "OUTPUT_DIR",
      "description": "Directory where composited images will be saved",
      "type": "path"
    },
    {
      "name": "OVERLAY",
      "description": "Path to the overlay image to composite on top of each input image",
      "type": "path"
    }
  ],
  "parameters": {},
  "inputPorts": [],
  "outputPorts": [],
  "nodes": [
    {
      "id": "list-images",
      "type": "file-system",
      "version": "1.0.0",
      "name": "List Input Images",
      "position": {
        "x": 100,
        "y": 100
      },
      "metadata": {
        "description": "Lists all image files in the input directory. Supports common image formats (PNG, JPG, JPEG)."
      },
      "parameters": {
        "operation": "list",
        "path": "{{.INPUT_DIR}}"
      },
      "inputPorts": [],
      "outputPorts": [
        {
          "id": "out-1",
          "name": "files"
        }
      ]
    },
    {
      "id": "create-output-dir",
      "type": "file-system",
      "version": "1.0.0",
      "name": "Create Output Directory",
      "position": {
        "x": 100,
        "y": 200
      },
      "metadata": {
        "description": "Creates the output directory if it doesn't exist"
      },
      "parameters": {
        "operation": "mkdir",
        "path": "{{.OUTPUT_DIR}}",
        "recursive": true
      },
      "inputPorts": [],
      "outputPorts": []
    },
    {
      "id": "composite-loop",
      "type": "loop",
      "version": "1.0.0",
      "name": "Composite Each Image",
      "position": {
        "x": 300,
        "y": 100
      },
      "metadata": {
        "description": "Loops through each image file and composites the overlay on top of it. The {{.item}} template resolves to the current file path."
      },
      "parameters": {
        "mode": "forEach",
        "items": "{{index . \"list-images\" \"files\"}}",
        "showProgress": true
      },
      "inputPorts": [
        {
          "id": "in-1",
          "name": "items"
        }
      ],
      "outputPorts": [],
      "nodes": [
        {
          "id": "composite-image",
          "type": "image",
          "version": "1.0.0",
          "name": "Composite Overlay on Image",
          "position": {
            "x": 100,
            "y": 100
          },
          "metadata": {
            "description": "Composites the overlay image on top of the current input image. The overlay is centered on the base image by default."
          },
          "parameters": {
            "operation": "composite",
            "base": "{{.item}}",
            "overlay": "{{$.OVERLAY}}",
            "output": "{{$.OUTPUT_DIR}}/{{basename .item}}",
            "position": "center",
            "format": "png",
            "quality": 95
          },
          "inputPorts": [],
          "outputPorts": []
        }
      ],
      "edges": []
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "list-images",
      "target": "composite-loop",
      "sourcePort": "out-1",
      "targetPort": "in-1"
    }
  ]
}
