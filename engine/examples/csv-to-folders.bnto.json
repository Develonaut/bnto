{
  "id": "folder-setup",
  "type": "group",
  "version": "1.0.0",
  "name": "CSV Folder Setup",
  "position": {
    "x": 0,
    "y": 0
  },
  "metadata": {
    "description": "Creates folder structure for each row from CSV. Demonstrates loop node with forEach mode and context passing from CSV reader to file-system operations.",
    "usage": "bnto run csv-to-folders.bnto.json",
    "example": "Reads tests/fixtures/test-data.csv and creates output/Test Item A/, output/Test Item B/, output/Test Item C/",
    "tags": ["folders", "loop", "filesystem", "csv"],
    "demonstrates": ["forEach loop", "template resolution", "context passing", "nested node execution"]
  },
  "parameters": {},
  "inputPorts": [],
  "outputPorts": [],
  "nodes": [
    {
      "id": "read-csv",
      "type": "spreadsheet",
      "version": "1.0.0",
      "name": "Read Data CSV",
      "position": {
        "x": 100,
        "y": 100
      },
      "metadata": {
        "description": "Reads CSV and outputs array of row maps with keys: id, name, description, category"
      },
      "parameters": {
        "operation": "read",
        "format": "csv",
        "path": "tests/fixtures/test-data.csv",
        "hasHeaders": true
      },
      "inputPorts": [],
      "outputPorts": [
        {
          "id": "out-1",
          "name": "rows"
        }
      ]
    },
    {
      "id": "create-folders",
      "type": "loop",
      "version": "1.0.0",
      "name": "Create Folder for Each Row",
      "position": {
        "x": 300,
        "y": 100
      },
      "metadata": {
        "description": "Loops through each row and creates its folder. Uses {{index . \"read-csv\" \"rows\"}} to access the CSV data from the previous node. Inside the loop, {{.item.name}} accesses the current row's name field."
      },
      "parameters": {
        "mode": "forEach",
        "items": "{{index . \"read-csv\" \"rows\"}}",
        "showProgress": true
      },
      "inputPorts": [
        {
          "id": "in-1",
          "name": "items"
        }
      ],
      "outputPorts": [],
      "nodes": [
        {
          "id": "mkdir",
          "type": "file-system",
          "version": "1.0.0",
          "name": "Create Directory",
          "position": {
            "x": 100,
            "y": 100
          },
          "metadata": {
            "description": "Creates output/[item name]/ directory for the current row. The {{.item.name}} template resolves to the name value from the current CSV row. The 'recursive: true' parameter ensures parent directories are created if needed."
          },
          "parameters": {
            "operation": "mkdir",
            "path": "output/{{.item.name}}",
            "recursive": true
          },
          "inputPorts": [],
          "outputPorts": []
        }
      ],
      "edges": []
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "read-csv",
      "target": "create-folders",
      "sourcePort": "out-1",
      "targetPort": "in-1"
    }
  ]
}
