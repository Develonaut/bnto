{
  "id": "image-composite",
  "type": "group",
  "version": "1.0.0",
  "name": "Image Composite",
  "position": { "x": 0, "y": 0 },
  "metadata": {
    "description": "Lists images and composites an overlay onto each one."
  },
  "parameters": {},
  "inputPorts": [],
  "outputPorts": [],
  "nodes": [
    {
      "id": "list-images",
      "type": "file-system",
      "version": "1.0.0",
      "name": "List Images",
      "position": { "x": 100, "y": 100 },
      "metadata": {},
      "parameters": {
        "operation": "list",
        "path": "tests/fixtures/images/*.png"
      },
      "inputPorts": [],
      "outputPorts": [{ "id": "out-1", "name": "files" }]
    },
    {
      "id": "composite-loop",
      "type": "loop",
      "version": "1.0.0",
      "name": "Composite Each Image",
      "position": { "x": 300, "y": 100 },
      "metadata": {},
      "parameters": {
        "mode": "forEach",
        "items": "{{index . \"list-images\" \"files\"}}"
      },
      "inputPorts": [{ "id": "in-1", "name": "items" }],
      "outputPorts": [],
      "nodes": [
        {
          "id": "composite-image",
          "type": "image",
          "version": "1.0.0",
          "name": "Composite Image",
          "position": { "x": 100, "y": 100 },
          "metadata": {},
          "parameters": {
            "operation": "composite",
            "base": "{{.item}}",
            "overlay": "tests/fixtures/overlays/0.png",
            "output": "{{.COMPOSITE_OUTPUT}}/{{basename .item}}",
            "position": "center"
          },
          "inputPorts": [],
          "outputPorts": []
        }
      ],
      "edges": []
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "list-images",
      "target": "composite-loop"
    }
  ]
}
