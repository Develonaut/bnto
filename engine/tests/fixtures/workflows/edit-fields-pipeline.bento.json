{
  "id": "edit-fields-pipeline",
  "type": "group",
  "version": "1.0.0",
  "name": "Edit Fields Pipeline",
  "position": { "x": 0, "y": 0 },
  "metadata": {
    "description": "Sets fields then transforms them with derived values."
  },
  "parameters": {},
  "inputPorts": [],
  "outputPorts": [],
  "nodes": [
    {
      "id": "setFields",
      "type": "edit-fields",
      "version": "1.0.0",
      "name": "Set Product Fields",
      "position": { "x": 100, "y": 100 },
      "metadata": {},
      "parameters": {
        "values": {
          "productName": "Bento Widget",
          "price": 29.99,
          "category": "tools",
          "inStock": true
        }
      },
      "inputPorts": [],
      "outputPorts": [{ "id": "out-1", "name": "fields" }]
    },
    {
      "id": "transformFields",
      "type": "transform",
      "version": "1.0.0",
      "name": "Derive Labels",
      "position": { "x": 300, "y": 100 },
      "metadata": {},
      "parameters": {
        "mappings": {
          "label": "setFields[\"productName\"] + \" - \" + setFields[\"category\"]",
          "hasPrice": "setFields[\"price\"] > 0"
        }
      },
      "inputPorts": [{ "id": "in-1", "name": "data" }],
      "outputPorts": [{ "id": "out-1", "name": "result" }]
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "setFields",
      "target": "transformFields"
    }
  ]
}
