# ──────────────────────────────────────────────
# Frontend (apps/web/.env.local)
# ──────────────────────────────────────────────

NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site

# ──────────────────────────────────────────────
# Convex Dashboard — Server-Side Secrets
# Set per-environment in the Convex Dashboard,
# NOT in .env files.
# ──────────────────────────────────────────────

# Auth
# BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
# SITE_URL=http://localhost:3000

# Auth Providers (deferred — not yet enabled)
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
# AUTH_DISCORD_ID=your-discord-client-id
# AUTH_DISCORD_SECRET=your-discord-client-secret

# R2 Storage (transit layer)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=bnto-transit-dev

# Cloud Execution
# GO_API_URL=https://your-api.up.railway.app
# ANONYMOUS_RUN_LIMIT=3
