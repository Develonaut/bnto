# Convex Cloud
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-app.vercel.app

# Convex self-hosted (Railway — alternative to Convex Cloud)
# CONVEX_SELF_HOSTED_URL=https://your-convex-backend.up.railway.app
# CONVEX_SELF_HOSTED_ADMIN_KEY=your-instance|your-admin-key

# Convex server environment (set in Convex dashboard)
# SITE_URL=https://your-app.vercel.app
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
# AUTH_DISCORD_ID=your-discord-client-id
# AUTH_DISCORD_SECRET=your-discord-client-secret
# GO_API_URL=https://your-api.up.railway.app

# Auth — passphrase gate (optional, defaults to "hotdogbowl")
BNTO_PASSPHRASE=your-passphrase
